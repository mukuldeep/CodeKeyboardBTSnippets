{
  "Topological Sort (Kahn)": {
    "prefix": "topo_kahn",
    "body": [
      "vector<int> topo_sort(int n, vector<vector<int>>& adj) {",
      "    vector<int> indeg(n+1, 0);",
      "    for(int u=1;u<=n;u++)",
      "        for(int v: adj[u]) indeg[v]++;",
      "",
      "    queue<int> q;",
      "    for(int i=1;i<=n;i++)",
      "        if(indeg[i]==0) q.push(i);",
      "",
      "    vector<int> topo;",
      "    while(!q.empty()){",
      "        int u=q.front(); q.pop();",
      "        topo.push_back(u);",
      "        for(int v:adj[u]){",
      "            if(--indeg[v]==0) q.push(v);",
      "        }",
      "    }",
      "    return topo;",
      "}"
    ],
    "description": "Topological sort using Kahn's algorithm"
  },

  "Topological Sort (DFS)": {
    "prefix": "topo_dfs",
    "body": [
      "void dfs_topo(int u, vector<vector<int>>& adj, vector<int>& vis, vector<int>& order){",
      "    vis[u]=1;",
      "    for(int v:adj[u])",
      "        if(!vis[v]) dfs_topo(v,adj,vis,order);",
      "    order.push_back(u);",
      "}"
    ],
    "description": "Topological sort using DFS"
  },

  "SCC (Kosaraju)": {
    "prefix": "scc_kosaraju",
    "body": [
      "void dfs1(int u, vector<vector<int>>& adj, vector<int>& vis, vector<int>& order){",
      "    vis[u]=1;",
      "    for(int v:adj[u])",
      "        if(!vis[v]) dfs1(v,adj,vis,order);",
      "    order.push_back(u);",
      "}",
      "",
      "void dfs2(int u, vector<vector<int>>& radj, vector<int>& comp, int c){",
      "    comp[u]=c;",
      "    for(int v:radj[u])",
      "        if(!comp[v]) dfs2(v,radj,comp,c);",
      "}"
    ],
    "description": "Strongly Connected Components - Kosaraju"
  },

  "SCC (Tarjan)": {
    "prefix": "scc_tarjan",
    "body": [
      "vector<int> disc, low, st, inStack;",
      "int timer_scc=0;",
      "",
      "void tarjan(int u, vector<vector<int>>& adj){",
      "    disc[u]=low[u]=++timer_scc;",
      "    st.push_back(u); inStack[u]=1;",
      "",
      "    for(int v:adj[u]){",
      "        if(!disc[v]){",
      "            tarjan(v,adj);",
      "            low[u]=min(low[u],low[v]);",
      "        } else if(inStack[v]){",
      "            low[u]=min(low[u],disc[v]);",
      "        }",
      "    }",
      "",
      "    if(disc[u]==low[u]){",
      "        while(true){",
      "            int v=st.back(); st.pop_back();",
      "            inStack[v]=0;",
      "            if(v==u) break;",
      "        }",
      "    }",
      "}"
    ],
    "description": "Strongly Connected Components - Tarjan"
  },

  "Bridges (Tarjan)": {
    "prefix": "bridges",
    "body": [
      "vector<int> tin, low;",
      "int timer_bridge=0;",
      "",
      "void dfs_bridge(int u,int p,vector<vector<int>>& adj){",
      "    tin[u]=low[u]=++timer_bridge;",
      "    for(int v:adj[u]){",
      "        if(v==p) continue;",
      "        if(!tin[v]){",
      "            dfs_bridge(v,u,adj);",
      "            low[u]=min(low[u],low[v]);",
      "            if(low[v]>tin[u]){",
      "                // u-v is a bridge",
      "            }",
      "        } else {",
      "            low[u]=min(low[u],tin[v]);",
      "        }",
      "    }",
      "}"
    ],
    "description": "Bridge finding using Tarjan"
  },

  "Articulation Points": {
    "prefix": "articulation",
    "body": [
      "vector<int> tin_ap, low_ap, isArt;",
      "int timer_ap=0;",
      "",
      "void dfs_ap(int u,int p,vector<vector<int>>& adj){",
      "    tin_ap[u]=low_ap[u]=++timer_ap;",
      "    int children=0;",
      "",
      "    for(int v:adj[u]){",
      "        if(v==p) continue;",
      "        if(!tin_ap[v]){",
      "            dfs_ap(v,u,adj);",
      "            low_ap[u]=min(low_ap[u],low_ap[v]);",
      "            if(low_ap[v]>=tin_ap[u] && p!=-1)",
      "                isArt[u]=1;",
      "            children++;",
      "        } else {",
      "            low_ap[u]=min(low_ap[u],tin_ap[v]);",
      "        }",
      "    }",
      "    if(p==-1 && children>1) isArt[u]=1;",
      "}"
    ],
    "description": "Articulation points in graph"
  },

  "DSU (Union-Find)": {
    "prefix": "dsu",
    "body": [
      "struct DSU{",
      "    vector<int> parent,sz;",
      "    DSU(int n){",
      "        parent.resize(n+1); sz.assign(n+1,1);",
      "        iota(parent.begin(),parent.end(),0);",
      "    }",
      "    int find(int x){",
      "        if(parent[x]==x) return x;",
      "        return parent[x]=find(parent[x]);",
      "    }",
      "    void unite(int a,int b){",
      "        a=find(a); b=find(b);",
      "        if(a!=b){",
      "            if(sz[a]<sz[b]) swap(a,b);",
      "            parent[b]=a;",
      "            sz[a]+=sz[b];",
      "        }",
      "    }",
      "};"
    ],
    "description": "Disjoint Set Union with path compression"
  },

  "DSU with Rollback": {
    "prefix": "dsu_rollback",
    "body": [
      "struct DSU{",
      "    vector<int> parent,sz;",
      "    stack<pair<int,int>> history;",
      "",
      "    DSU(int n){",
      "        parent.resize(n+1); sz.assign(n+1,1);",
      "        iota(parent.begin(),parent.end(),0);",
      "    }",
      "",
      "    int find(int x){",
      "        while(x!=parent[x]) x=parent[x];",
      "        return x;",
      "    }",
      "",
      "    void unite(int a,int b){",
      "        a=find(a); b=find(b);",
      "        if(a==b){ history.push({-1,-1}); return; }",
      "        if(sz[a]<sz[b]) swap(a,b);",
      "        parent[b]=a;",
      "        sz[a]+=sz[b];",
      "        history.push({a,b});",
      "    }",
      "",
      "    void rollback(){",
      "        auto [a,b]=history.top(); history.pop();",
      "        if(a==-1) return;",
      "        parent[b]=b;",
      "        sz[a]-=sz[b];",
      "    }",
      "};"
    ],
    "description": "DSU with rollback support"
  },

  "MST (Kruskal)": {
    "prefix": "mst_kruskal",
    "body": [
      "long long kruskal(int n, vector<tuple<int,int,int>>& edges){",
      "    sort(edges.begin(),edges.end());",
      "    DSU dsu(n);",
      "    long long cost=0;",
      "    for(auto [w,u,v]:edges){",
      "        if(dsu.find(u)!=dsu.find(v)){",
      "            dsu.unite(u,v);",
      "            cost+=w;",
      "        }",
      "    }",
      "    return cost;",
      "}"
    ],
    "description": "Minimum Spanning Tree - Kruskal"
  },

  "MST (Prim)": {
    "prefix": "mst_prim",
    "body": [
      "long long prim(int n, vector<vector<pair<int,int>>>& adj){",
      "    vector<int> vis(n+1,0);",
      "    priority_queue<pair<int,int>,vector<pair<int,int>>,greater<pair<int,int>>> pq;",
      "    pq.push({0,1});",
      "    long long cost=0;",
      "",
      "    while(!pq.empty()){",
      "        auto [w,u]=pq.top(); pq.pop();",
      "        if(vis[u]) continue;",
      "        vis[u]=1;",
      "        cost+=w;",
      "        for(auto [v,wt]:adj[u])",
      "            if(!vis[v]) pq.push({wt,v});",
      "    }",
      "    return cost;",
      "}"
    ],
    "description": "Minimum Spanning Tree - Prim"
  },

  "Binary Lifting Template": {
    "prefix": "binary_lift",
    "body": [
      "const int LOG=20;",
      "vector<vector<int>> up;",
      "vector<int> depth;",
      "",
      "void dfs_lift(int u,int p,vector<vector<int>>& adj){",
      "    up[u][0]=p;",
      "    for(int i=1;i<LOG;i++)",
      "        up[u][i]=up[up[u][i-1]][i-1];",
      "",
      "    for(int v:adj[u])",
      "        if(v!=p){",
      "            depth[v]=depth[u]+1;",
      "            dfs_lift(v,u,adj);",
      "        }",
      "}"
    ],
    "description": "Binary lifting parent table template"
  },

  "Heavy Light Decomposition (HLD)": {
    "prefix": "hld",
    "body": [
      "vector<int> parent,depth,heavy,head,pos,sz;",
      "int cur_pos=0;",
      "",
      "int dfs_hld(int u, vector<vector<int>>& adj){",
      "    sz[u]=1;",
      "    int max_sz=0;",
      "    for(int v:adj[u]){",
      "        if(v!=parent[u]){",
      "            parent[v]=u;",
      "            depth[v]=depth[u]+1;",
      "            int sub=dfs_hld(v,adj);",
      "            sz[u]+=sub;",
      "            if(sub>max_sz){",
      "                max_sz=sub;",
      "                heavy[u]=v;",
      "            }",
      "        }",
      "    }",
      "    return sz[u];",
      "}",
      "",
      "void decompose(int u,int h,vector<vector<int>>& adj){",
      "    head[u]=h;",
      "    pos[u]=++cur_pos;",
      "",
      "    if(heavy[u]!=-1)",
      "        decompose(heavy[u],h,adj);",
      "",
      "    for(int v:adj[u]){",
      "        if(v!=parent[u] && v!=heavy[u])",
      "            decompose(v,v,adj);",
      "    }",
      "}"
    ],
    "description": "Heavy Light Decomposition base template"
  }
}