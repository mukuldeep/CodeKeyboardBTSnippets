{
  "Ford-Fulkerson (DFS)": {
    "prefix": "flow_ford_fulkerson",
    "body": [
      "// Ford-Fulkerson using DFS (O(E * max_flow))",
      "struct Edge {",
      "    int v;",
      "    long long cap;",
      "    int rev;",
      "};",
      "",
      "vector<vector<Edge>> graph;",
      "",
      "void addEdge(int u, int v, long long cap) {",
      "    graph[u].push_back({v, cap, (int)graph[v].size()});",
      "    graph[v].push_back({u, 0, (int)graph[u].size() - 1});",
      "}",
      "",
      "long long dfs(int u, int t, long long flow, vector<int> &vis) {",
      "    if (u == t) return flow;",
      "    vis[u] = 1;",
      "",
      "    for (auto &e : graph[u]) {",
      "        if (!vis[e.v] && e.cap > 0) {",
      "            long long pushed = dfs(e.v, t, min(flow, e.cap), vis);",
      "            if (pushed) {",
      "                e.cap -= pushed;",
      "                graph[e.v][e.rev].cap += pushed;",
      "                return pushed;",
      "            }",
      "        }",
      "    }",
      "    return 0;",
      "}",
      "",
      "long long maxFlow(int n, int s, int t) {",
      "    long long flow = 0;",
      "    while (true) {",
      "        vector<int> vis(n, 0);",
      "        long long pushed = dfs(s, t, LLONG_MAX, vis);",
      "        if (!pushed) break;",
      "        flow += pushed;",
      "    }",
      "    return flow;",
      "}"
    ],
    "description": "Ford-Fulkerson using DFS"
  },

  "Dinic Algorithm": {
    "prefix": "flow_dinic",
    "body": [
      "// Dinic's Algorithm O(E * sqrt(V)) / O(min(V^(2/3), sqrt(E)) * E)",
      "struct Edge {",
      "    int v;",
      "    long long cap;",
      "    int rev;",
      "};",
      "",
      "vector<vector<Edge>> graph;",
      "vector<int> level, ptr;",
      "",
      "void addEdge(int u, int v, long long cap) {",
      "    graph[u].push_back({v, cap, (int)graph[v].size()});",
      "    graph[v].push_back({u, 0, (int)graph[u].size() - 1});",
      "}",
      "",
      "bool bfs(int s, int t) {",
      "    queue<int> q;",
      "    level.assign(graph.size(), -1);",
      "    level[s] = 0;",
      "    q.push(s);",
      "",
      "    while (!q.empty()) {",
      "        int u = q.front(); q.pop();",
      "        for (auto &e : graph[u]) {",
      "            if (e.cap > 0 && level[e.v] == -1) {",
      "                level[e.v] = level[u] + 1;",
      "                q.push(e.v);",
      "            }",
      "        }",
      "    }",
      "    return level[t] != -1;",
      "}",
      "",
      "long long dfs(int u, int t, long long flow) {",
      "    if (!flow) return 0;",
      "    if (u == t) return flow;",
      "",
      "    for (int &cid = ptr[u]; cid < (int)graph[u].size(); cid++) {",
      "        Edge &e = graph[u][cid];",
      "        if (e.cap > 0 && level[e.v] == level[u] + 1) {",
      "            long long pushed = dfs(e.v, t, min(flow, e.cap));",
      "            if (pushed) {",
      "                e.cap -= pushed;",
      "                graph[e.v][e.rev].cap += pushed;",
      "                return pushed;",
      "            }",
      "        }",
      "    }",
      "    return 0;",
      "}",
      "",
      "long long maxFlow(int s, int t) {",
      "    long long flow = 0;",
      "    while (bfs(s, t)) {",
      "        ptr.assign(graph.size(), 0);",
      "        while (long long pushed = dfs(s, t, LLONG_MAX)) {",
      "            flow += pushed;",
      "        }",
      "    }",
      "    return flow;",
      "}"
    ],
    "description": "Dinic max flow"
  },

  "Hopcroft-Karp (Bipartite Matching)": {
    "prefix": "flow_hopcroft_karp",
    "body": [
      "// Hopcroft-Karp O(E * sqrt(V))",
      "struct HopcroftKarp {",
      "    int n, m;",
      "    vector<vector<int>> adj;",
      "    vector<int> dist, matchR, matchL;",
      "",
      "    HopcroftKarp(int n, int m) : n(n), m(m) {",
      "        adj.assign(n + 1, {});",
      "        matchL.assign(n + 1, 0);",
      "        matchR.assign(m + 1, 0);",
      "        dist.resize(n + 1);",
      "    }",
      "",
      "    void addEdge(int u, int v) {",
      "        adj[u].push_back(v);",
      "    }",
      "",
      "    bool bfs() {",
      "        queue<int> q;",
      "        for (int i = 1; i <= n; i++) {",
      "            if (!matchL[i]) {",
      "                dist[i] = 0;",
      "                q.push(i);",
      "            } else dist[i] = -1;",
      "        }",
      "",
      "        bool found = false;",
      "        while (!q.empty()) {",
      "            int u = q.front(); q.pop();",
      "            for (int v : adj[u]) {",
      "                if (!matchR[v]) found = true;",
      "                else if (dist[matchR[v]] == -1) {",
      "                    dist[matchR[v]] = dist[u] + 1;",
      "                    q.push(matchR[v]);",
      "                }",
      "            }",
      "        }",
      "        return found;",
      "    }",
      "",
      "    bool dfs(int u) {",
      "        for (int v : adj[u]) {",
      "            if (!matchR[v] ||",
      "                (dist[matchR[v]] == dist[u] + 1 && dfs(matchR[v]))) {",
      "                matchL[u] = v;",
      "                matchR[v] = u;",
      "                return true;",
      "            }",
      "        }",
      "        dist[u] = -1;",
      "        return false;",
      "    }",
      "",
      "    int maxMatching() {",
      "        int matching = 0;",
      "        while (bfs()) {",
      "            for (int i = 1; i <= n; i++)",
      "                if (!matchL[i] && dfs(i))",
      "                    matching++;",
      "        }",
      "        return matching;",
      "    }",
      "};"
    ],
    "description": "Hopcroft-Karp bipartite matching"
  },

  "Min-Cost Max-Flow (SPFA)": {
    "prefix": "flow_mcmf",
    "body": [
      "// Min-Cost Max-Flow using SPFA",
      "struct Edge {",
      "    int v, rev;",
      "    long long cap, cost;",
      "};",
      "",
      "vector<vector<Edge>> graph;",
      "",
      "void addEdge(int u, int v, long long cap, long long cost) {",
      "    graph[u].push_back({v, (int)graph[v].size(), cap, cost});",
      "    graph[v].push_back({u, (int)graph[u].size() - 1, 0, -cost});",
      "}",
      "",
      "pair<long long,long long> minCostMaxFlow(int s, int t, int n) {",
      "    long long flow = 0, cost = 0;",
      "    while (true) {",
      "        vector<long long> dist(n, LLONG_MAX);",
      "        vector<int> inq(n, 0), parentV(n), parentE(n);",
      "        queue<int> q;",
      "",
      "        dist[s] = 0;",
      "        q.push(s);",
      "        inq[s] = 1;",
      "",
      "        while (!q.empty()) {",
      "            int u = q.front(); q.pop();",
      "            inq[u] = 0;",
      "            for (int i = 0; i < graph[u].size(); i++) {",
      "                Edge &e = graph[u][i];",
      "                if (e.cap > 0 && dist[e.v] > dist[u] + e.cost) {",
      "                    dist[e.v] = dist[u] + e.cost;",
      "                    parentV[e.v] = u;",
      "                    parentE[e.v] = i;",
      "                    if (!inq[e.v]) {",
      "                        q.push(e.v);",
      "                        inq[e.v] = 1;",
      "                    }",
      "                }",
      "            }",
      "        }",
      "",
      "        if (dist[t] == LLONG_MAX) break;",
      "",
      "        long long pushed = LLONG_MAX;",
      "        for (int v = t; v != s; v = parentV[v]) {",
      "            pushed = min(pushed, graph[parentV[v]][parentE[v]].cap);",
      "        }",
      "",
      "        for (int v = t; v != s; v = parentV[v]) {",
      "            Edge &e = graph[parentV[v]][parentE[v]];",
      "            e.cap -= pushed;",
      "            graph[v][e.rev].cap += pushed;",
      "        }",
      "",
      "        flow += pushed;",
      "        cost += pushed * dist[t];",
      "    }",
      "",
      "    return {flow, cost};",
      "}"
    ],
    "description": "Min-Cost Max-Flow using SPFA"
  }
}