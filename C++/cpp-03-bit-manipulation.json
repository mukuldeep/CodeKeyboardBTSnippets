{
  "GCC Builtins (popcount, clz, ctz)": {
    "prefix": "bit_builtins",
    "body": [
      "// GCC Builtins",
      "// __builtin_popcount(x)  -> number of set bits (int)",
      "// __builtin_popcountll(x) -> number of set bits (long long)",
      "// __builtin_clz(x)  -> leading zeros (undefined if x=0)",
      "// __builtin_ctz(x)  -> trailing zeros (undefined if x=0)",
      "// __builtin_parity(x) -> parity of bits",
      "",
      "int cnt = __builtin_popcount(x);",
      "int cntll = __builtin_popcountll(x);",
      "int lz = __builtin_clz(x);",
      "int tz = __builtin_ctz(x);",
      "int parity = __builtin_parity(x);"
    ]
  },

  "Check Power of Two": {
    "prefix": "bit_pow2",
    "body": [
      "// Check if x is power of 2",
      "bool isPowerOfTwo(long long x) {",
      "    return x > 0 && (x & (x - 1)) == 0;",
      "}"
    ]
  },

  "Turn Off Lowest Set Bit": {
    "prefix": "bit_remove_lowest",
    "body": [
      "// Remove lowest set bit",
      "x = x & (x - 1);"
    ]
  },

  "Get Lowest Set Bit": {
    "prefix": "bit_lowest",
    "body": [
      "// Get lowest set bit",
      "long long lowest = x & (-x);"
    ]
  },

  "Iterate All Submasks": {
