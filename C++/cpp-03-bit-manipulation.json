    "body": [
      "// Iterate over all submasks of mask",
      "for (int sub = mask; sub; sub = (sub - 1) & mask) {",
      "    // process sub",
      "}",
      "// If need to include 0:",
      "// for (int sub = mask; ; sub = (sub - 1) & mask) {",
      "//     if (sub == 0) break;",
      "// }"
    ]
  },

  "Iterate All Masks (0 to 2^n-1)": {
    "prefix": "bit_all_masks",
    "body": [
      "for (int mask = 0; mask < (1 << n); mask++) {",
      "    // process mask",
      "}"
    ]
  },

  "Count Bits DP (0 to N)": {
    "prefix": "bit_count_dp",
    "body": [
      "// Count bits from 0 to n",
      "vector<int> countBits(int n) {",
      "    vector<int> dp(n + 1);",
      "    for (int i = 1; i <= n; i++) {",
      "        dp[i] = dp[i >> 1] + (i & 1);",
      "    }",
      "    return dp;",
      "}"
    ]
  },

  "XOR Swap": {
    "prefix": "bit_xor_swap",
    "body": [
      "// XOR Swap (avoid if same variable)",
      "a ^= b;",
      "b ^= a;",
      "a ^= b;"
    ]
  },

  "Find Single Element (Others Twice)": {
    "prefix": "bit_single_element",
    "body": [
      "// Every element appears twice except one",
      "int singleNumber(vector<int>& nums) {",
      "    int ans = 0;",
      "    for (int x : nums) ans ^= x;",
      "    return ans;",
      "}"
    ]
  },

  "Find Two Unique Elements": {
    "prefix": "bit_two_unique",
    "body": [
      "// Two numbers appear once, others twice",
      "pair<int,int> findTwo(vector<int>& nums) {",
      "    int x = 0;",
      "    for (int n : nums) x ^= n;",
      "    int diff = x & (-x);",
      "    int a = 0, b = 0;",
      "    for (int n : nums) {",
      "        if (n & diff) a ^= n;",
      "        else b ^= n;",
      "    }",
      "    return {a, b};",
      "}"
    ]
  },

  "Gray Code Generation": {
    "prefix": "bit_gray",
    "body": [
      "// Generate n-bit Gray code",
      "vector<int> grayCode(int n) {",
      "    vector<int> res;",
      "    for (int i = 0; i < (1 << n); i++) {",
      "        res.push_back(i ^ (i >> 1));",
      "    }",
      "    return res;",
      "}"
    ]
  },

  "Subset Sum via Bitmask": {
    "prefix": "bit_subset_sum",
    "body": [
      "// Subset sum using bitmask",
      "for (int mask = 0; mask < (1 << n); mask++) {",
      "    long long sum = 0;",
      "    for (int i = 0; i < n; i++) {",
      "        if (mask & (1 << i)) sum += arr[i];",
      "    }",
      "}"
    ]
  },

  "SOS DP (Sum Over Subsets)": {
    "prefix": "bit_sos_dp",
    "body": [
      "// SOS DP",
      "for (int i = 0; i < n; i++) {",
      "    for (int mask = 0; mask < (1 << n); mask++) {",
      "        if (mask & (1 << i)) {",
      "            dp[mask] += dp[mask ^ (1 << i)];",
      "        }",
      "    }",
      "}"
    ]
  },

  "Bitset Optimization (Knapsack Style)": {
    "prefix": "bit_bitset_knapsack",
    "body": [
      "// Bitset optimization (subset sum)",
      "const int MAX = 100000;",
      "bitset<MAX> bs;",
      "bs[0] = 1;",
      "for (int x : arr) {",
      "    bs |= (bs << x);",
      "}"
    ]
  },

  "Enumerate Set Bits Efficiently": {
    "prefix": "bit_enumerate_setbits",
    "body": [
      "// Enumerate set bits",
      "for (int x = mask; x; x &= (x - 1)) {",
      "    int bit = __builtin_ctz(x);",
      "    // process bit",
      "}"
    ]
  },

  "Next Combination (Same Popcount)": {
    "prefix": "bit_next_comb",
    "body": [
      "// Next mask with same popcount",
      "int next_combination(int x) {",
      "    int u = x & -x;",
      "    int v = u + x;",
      "    return v + (((v ^ x) / u) >> 2);",
      "}"
    ]
  },

  "Check Opposite Signs": {
    "prefix": "bit_opposite_sign",
    "body": [
      "// Check if two integers have opposite signs",
      "bool oppositeSigns(int a, int b) {",
      "    return (a ^ b) < 0;",
      "}"
    ]
  },

  "Multiply by Power of Two": {
    "prefix": "bit_mul_pow2",
    "body": [
      "// Multiply and divide by 2^k",
      "x << k; // x * 2^k",
      "x >> k; // x / 2^k (if x >= 0)"
    ]
  }
}