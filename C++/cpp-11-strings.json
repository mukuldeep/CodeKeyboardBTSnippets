      "// Aho-Corasick Automaton",
      "#include <bits/stdc++.h>",
      "using namespace std;",
      "",
      "struct AhoCorasick {",
      "    struct Node {",
      "        int nxt[26];",
      "        int link = -1;",
      "        vector<int> out;",
      "        Node() { memset(nxt, -1, sizeof(nxt)); }",
      "    };",
      "",
      "    vector<Node> t;",
      "    AhoCorasick() { t.push_back(Node()); }",
      "",
      "    void insert(const string &s, int id) {",
      "        int v = 0;",
      "        for (char c : s) {",
      "            int idx = c - 'a';",
      "            if (t[v].nxt[idx] == -1) {",
      "                t[v].nxt[idx] = t.size();",
      "                t.push_back(Node());",
      "            }",
      "            v = t[v].nxt[idx];",
      "        }",
      "        t[v].out.push_back(id);",
      "    }",
      "};"
    ],
    "description": "Aho-Corasick automaton"
  },

  "Manacher": {
    "prefix": "str_manacher",
    "body": [
      "// Manacher's Algorithm",
      "#include <bits/stdc++.h>",
      "using namespace std;",
      "",
      "vector<int> manacher(const string &s) {",
      "    string t = \"#\";",
      "    for (char c : s) t += c, t += '#';",
      "    int n = t.size();",
      "    vector<int> p(n);",
      "    for (int i = 0, l = 0, r = 0; i < n; i++) {",
      "        if (i < r) p[i] = min(r - i, p[l + r - i]);",
      "        while (i - p[i] - 1 >= 0 && i + p[i] + 1 < n &&",
      "               t[i - p[i] - 1] == t[i + p[i] + 1]) p[i]++;",
      "        if (i + p[i] > r) l = i - p[i], r = i + p[i];",
      "    }",
      "    return p;",
      "}"
    ],
    "description": "Manacher palindrome algorithm"
  },

  "Suffix Array": {
    "prefix": "str_suffix_array",
    "body": [
      "// Suffix Array (O(n log n))",
      "#include <bits/stdc++.h>",
      "using namespace std;",
      "",
      "vector<int> build_sa(string s) {",
      "    int n = s.size();",
      "    vector<int> sa(n), r(n), tmp(n);",
      "    for (int i = 0; i < n; i++) sa[i] = i, r[i] = s[i];",
      "    for (int k = 1; k < n; k <<= 1) {",
      "        auto cmp = [&](int i, int j) {",
      "            if (r[i] != r[j]) return r[i] < r[j];",
      "            int ri = i + k < n ? r[i+k] : -1;",
      "            int rj = j + k < n ? r[j+k] : -1;",
      "            return ri < rj;",
      "        };",
      "        sort(sa.begin(), sa.end(), cmp);",
      "        tmp[sa[0]] = 0;",
      "        for (int i = 1; i < n; i++)",
      "            tmp[sa[i]] = tmp[sa[i-1]] + cmp(sa[i-1], sa[i]);",
      "        r = tmp;",
      "    }",
      "    return sa;",
      "}"
    ],
    "description": "Suffix array construction"
  },

  "LCP Array": {
    "prefix": "str_lcp",
    "body": [
      "// LCP Array (Kasai)",
      "#include <bits/stdc++.h>",
      "using namespace std;",
      "",
      "vector<int> build_lcp(const string &s, const vector<int> &sa) {",
      "    int n = s.size();",
      "    vector<int> rank(n), lcp(n-1);",
      "    for (int i = 0; i < n; i++) rank[sa[i]] = i;",
      "    for (int i = 0, h = 0; i < n; i++) {",
      "        if (rank[i] > 0) {",
      "            int j = sa[rank[i] - 1];",
      "            while (i+h < n && j+h < n && s[i+h] == s[j+h]) h++;",
      "            lcp[rank[i] - 1] = h;",
      "            if (h > 0) h--;",
      "        }",
      "    }",
      "    return lcp;",
      "}"
    ],
    "description": "Kasai LCP array construction"
  }
