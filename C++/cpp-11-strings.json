{
  "KMP Algorithm": {
    "prefix": "str_kmp",
    "body": [
      "// KMP (Knuth-Morris-Pratt)",
      "#include <bits/stdc++.h>",
      "using namespace std;",
      "",
      "vector<int> compute_lps(const string &pat) {",
      "    int m = pat.size();",
      "    vector<int> lps(m);",
      "    for (int i = 1, len = 0; i < m;) {",
      "        if (pat[i] == pat[len]) lps[i++] = ++len;",
      "        else if (len) len = lps[len - 1];",
      "        else lps[i++] = 0;",
      "    }",
      "    return lps;",
      "}",
      "",
      "vector<int> kmp_search(const string &txt, const string &pat) {",
      "    vector<int> lps = compute_lps(pat), res;",
      "    for (int i = 0, j = 0; i < txt.size();) {",
      "        if (txt[i] == pat[j]) { i++; j++; }",
      "        if (j == pat.size()) {",
      "            res.push_back(i - j);",
      "            j = lps[j - 1];",
      "        } else if (i < txt.size() && txt[i] != pat[j]) {",
      "            if (j) j = lps[j - 1];",
      "            else i++;",
      "        }",
      "    }",
      "    return res;",
      "}"
    ],
    "description": "KMP string matching"
  },

  "Z Function": {
    "prefix": "str_z",
    "body": [
      "// Z-Function",
      "#include <bits/stdc++.h>",
      "using namespace std;",
      "",
      "vector<int> z_function(const string &s) {",
      "    int n = s.size();",
      "    vector<int> z(n);",
      "    for (int i = 1, l = 0, r = 0; i < n; i++) {",
      "        if (i <= r) z[i] = min(r - i + 1, z[i - l]);",
      "        while (i + z[i] < n && s[z[i]] == s[i + z[i]]) z[i]++;",
      "        if (i + z[i] - 1 > r) l = i, r = i + z[i] - 1;",
      "    }",
      "    return z;",
      "}"
    ],
    "description": "Z-function for pattern matching"
  },

  "Rolling Hash": {
    "prefix": "str_hash",
    "body": [
      "// Rolling Hash (Single Mod)",
      "#include <bits/stdc++.h>",
      "using namespace std;",
      "",
      "struct RollingHash {",
      "    static const long long mod = 1e9+7;",
      "    static const long long base = 31;",
      "    vector<long long> h, p;",
      "",
      "    RollingHash(const string &s) {",
      "        int n = s.size();",
      "        h.resize(n+1); p.resize(n+1);",
      "        p[0] = 1;",
      "        for (int i = 0; i < n; i++) {",
      "            p[i+1] = (p[i] * base) % mod;",
      "            h[i+1] = (h[i] * base + s[i]) % mod;",
      "        }",
      "    }",
      "",
      "    long long get(int l, int r) {",
      "        return (h[r] - h[l] * p[r-l] % mod + mod) % mod;",
      "    }",
      "};"
    ],
    "description": "Single rolling hash template"
  },

  "Double Hashing": {
    "prefix": "str_double_hash",
    "body": [
      "// Double Hashing",
      "#include <bits/stdc++.h>",
      "using namespace std;",
      "",
      "struct DoubleHash {",
      "    static const long long mod1 = 1e9+7;",
      "    static const long long mod2 = 1e9+9;",
      "    static const long long base = 31;",
      "    vector<long long> h1, h2, p1, p2;",
      "",
      "    DoubleHash(const string &s) {",
      "        int n = s.size();",
      "        h1.resize(n+1); h2.resize(n+1);",
      "        p1.resize(n+1); p2.resize(n+1);",
      "        p1[0] = p2[0] = 1;",
      "        for (int i = 0; i < n; i++) {",
      "            p1[i+1] = p1[i] * base % mod1;",
      "            p2[i+1] = p2[i] * base % mod2;",
      "            h1[i+1] = (h1[i] * base + s[i]) % mod1;",
      "            h2[i+1] = (h2[i] * base + s[i]) % mod2;",
      "        }",
      "    }",
      "};"
    ],
    "description": "Double hashing template"
  },

  "Rabin-Karp": {
    "prefix": "str_rabin",
    "body": [
      "// Rabin-Karp",
      "#include <bits/stdc++.h>",
      "using namespace std;",
      "",
      "vector<int> rabin_karp(const string &txt, const string &pat) {",
      "    const long long mod = 1e9+7, base = 31;",
      "    int n = txt.size(), m = pat.size();",
      "    if (m > n) return {};",
      "",
      "    long long hash_pat = 0, hash_txt = 0, power = 1;",
      "",
      "    for (int i = 0; i < m; i++) {",
      "        hash_pat = (hash_pat * base + pat[i]) % mod;",
      "        hash_txt = (hash_txt * base + txt[i]) % mod;",
      "        if (i) power = power * base % mod;",
      "    }",
      "",
      "    vector<int> res;",
      "    for (int i = 0; i <= n - m; i++) {",
      "        if (hash_pat == hash_txt) res.push_back(i);",
      "        if (i < n - m) {",
      "            hash_txt = (hash_txt - txt[i] * power % mod + mod) % mod;",
      "            hash_txt = (hash_txt * base + txt[i + m]) % mod;",
      "        }",
      "    }",
      "    return res;",
      "}"
    ],
    "description": "Rabin-Karp pattern matching"
  },

  "Trie": {
    "prefix": "str_trie",
    "body": [
      "// Trie (Lowercase a-z)",
      "#include <bits/stdc++.h>",
      "using namespace std;",
      "",
      "struct Trie {",
      "    struct Node {",
      "        int nxt[26];",
      "        bool end = false;",
      "        Node() { memset(nxt, -1, sizeof(nxt)); }",
      "    };",
      "",
      "    vector<Node> t;",
      "    Trie() { t.push_back(Node()); }",
      "",
      "    void insert(const string &s) {",
      "        int node = 0;",
      "        for (char c : s) {",
      "            int idx = c - 'a';",
      "            if (t[node].nxt[idx] == -1) {",
      "                t[node].nxt[idx] = t.size();",
      "                t.push_back(Node());",
      "            }",
      "            node = t[node].nxt[idx];",
      "        }",
      "        t[node].end = true;",
      "    }",
      "};"
    ],
    "description": "Trie data structure"
  },

