{
  "Fast Power (Binary Exponentiation)": {
    "prefix": "binexp",
    "body": [
      "long long binexp(long long a, long long b) {",
      "    long long res = 1;",
      "    while (b) {",
      "        if (b & 1) res = res * a;",
      "        a = a * a;",
      "        b >>= 1;",
      "    }",
      "    return res;",
      "}"
    ],
    "description": "Binary exponentiation without modulo"
  },

  "Fast Power with Mod": {
    "prefix": "binexpmod",
    "body": [
      "long long binexp(long long a, long long b, long long mod) {",
      "    long long res = 1;",
      "    a %= mod;",
      "    while (b) {",
      "        if (b & 1) res = (res * a) % mod;",
      "        a = (a * a) % mod;",
      "        b >>= 1;",
      "    }",
      "    return res;",
      "}"
    ],
    "description": "Binary exponentiation with modulo"
  },

  "GCD and LCM": {
    "prefix": "gcdlcm",
    "body": [
      "long long gcd(long long a, long long b) {",
      "    return b == 0 ? a : gcd(b, a % b);",
      "}",
      "",
      "long long lcm(long long a, long long b) {",
      "    return a / gcd(a, b) * b;",
      "}"
    ],
    "description": "GCD and LCM implementation"
  },

  "Extended GCD": {
    "prefix": "extgcd",
    "body": [
      "long long extgcd(long long a, long long b, long long &x, long long &y) {",
      "    if (b == 0) {",
      "        x = 1; y = 0;",
      "        return a;",
      "    }",
      "    long long x1, y1;",
      "    long long g = extgcd(b, a % b, x1, y1);",
      "    x = y1;",
      "    y = x1 - y1 * (a / b);",
      "    return g;",
      "}"
    ],
    "description": "Extended Euclidean Algorithm"
  },

  "Modular Inverse (Fermat)": {
    "prefix": "modinv",
    "body": [
      "long long modinv(long long a, long long mod) {",
      "    return binexp(a, mod - 2, mod);",
      "}"
    ],
    "description": "Modular inverse using Fermat's little theorem (prime mod)"
  },

  "Sieve of Eratosthenes": {
    "prefix": "sieve",
    "body": [
      "vector<int> sieve(int n) {",
      "    vector<bool> is_prime(n + 1, true);",
      "    vector<int> primes;",
      "    is_prime[0] = is_prime[1] = false;",
      "    for (int i = 2; i <= n; i++) {",
      "        if (is_prime[i]) {",
      "            primes.push_back(i);",
      "            for (long long j = 1LL * i * i; j <= n; j += i)",
      "                is_prime[j] = false;",
      "        }",
      "    }",
      "    return primes;",
      "}"
    ],
    "description": "Sieve of Eratosthenes returning primes up to n"
  },

  "Smallest Prime Factor (SPF Sieve)": {
    "prefix": "spf",
    "body": [
      "vector<int> spf;",
      "",
      "void build_spf(int n) {",
      "    spf.assign(n + 1, 0);",
      "    for (int i = 2; i <= n; i++) {",
      "        if (spf[i] == 0) {",
      "            for (int j = i; j <= n; j += i)",
      "                if (spf[j] == 0)",
      "                    spf[j] = i;",
      "        }",
      "    }",
      "}",
      "",
      "vector<int> factorize(int x) {",
      "    vector<int> factors;",
      "    while (x > 1) {",
      "        factors.push_back(spf[x]);",
      "        x /= spf[x];",
      "    }",
      "    return factors;",
      "}"
    ],
    "description": "Smallest Prime Factor sieve and fast factorization"
  },

  "nCr with Precomputation (Mod Prime)": {
    "prefix": "ncrmod",
    "body": [
      "const int MAXN = ${1:1000000};",
      "const long long MOD = ${2:1000000007};",
      "long long fact[MAXN], invfact[MAXN];",
      "",
      "long long binexp(long long a, long long b) {",
      "    long long res = 1;",
      "    while (b) {",
      "        if (b & 1) res = (res * a) % MOD;",
      "        a = (a * a) % MOD;",
      "        b >>= 1;",
      "    }",
      "    return res;",
      "}",
      "",
      "void init() {",
      "    fact[0] = 1;",
      "    for (int i = 1; i < MAXN; i++)",
      "        fact[i] = fact[i - 1] * i % MOD;",
      "",
      "    invfact[MAXN - 1] = binexp(fact[MAXN - 1], MOD - 2);",
      "    for (int i = MAXN - 2; i >= 0; i--)",
      "        invfact[i] = invfact[i + 1] * (i + 1) % MOD;",
      "}",
      "",
      "long long nCr(int n, int r) {",
      "    if (r < 0 || r > n) return 0;",
      "    return fact[n] * invfact[r] % MOD * invfact[n - r] % MOD;",
      "}"
    ],
    "description": "Precomputed nCr under prime modulo"
  },

  "Matrix Exponentiation (2x2 Fibonacci)": {
    "prefix": "matrixexp",
    "body": [
      "struct Matrix {",
      "    long long a[2][2];",
      "};",
      "",
      "Matrix multiply(Matrix x, Matrix y, long long mod) {",
      "    Matrix res = {};",
      "    for (int i = 0; i < 2; i++)",
      "        for (int j = 0; j < 2; j++)",
      "            for (int k = 0; k < 2; k++)",
      "                res.a[i][j] = (res.a[i][j] +",
      "                    x.a[i][k] * y.a[k][j]) % mod;",
      "    return res;",
      "}",
      "",
      "Matrix matpow(Matrix base, long long exp, long long mod) {",
      "    Matrix res = {{{1,0},{0,1}}};",
      "    while (exp) {",
      "        if (exp & 1) res = multiply(res, base, mod);",
      "        base = multiply(base, base, mod);",
      "        exp >>= 1;",
      "    }",
      "    return res;",
      "}"
    ],
    "description": "2x2 matrix exponentiation template"
  },

  "Euler Totient Function (Single n)": {
    "prefix": "phi",
    "body": [
      "long long phi(long long n) {",
      "    long long result = n;",
      "    for (long long i = 2; i * i <= n; i++) {",
      "        if (n % i == 0) {",
      "            while (n % i == 0) n /= i;",
      "            result -= result / i;",
      "        }",
      "    }",
      "    if (n > 1) result -= result / n;",
      "    return result;",
      "}"
    ],
    "description": "Euler Totient function for single n"
  }
}