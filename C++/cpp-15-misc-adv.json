{
  "Meet in the Middle (Subset Sum)": {
    "prefix": "misc_mitm",
    "body": [
      "// Meet in the Middle - Subset Sum (n <= 40)",
      "long long meetInMiddle(vector<long long> &a, long long target) {",
      "    int n = a.size();",
      "    int mid = n / 2;",
      "",
      "    vector<long long> left, right;",
      "",
      "    for (int mask = 0; mask < (1 << mid); mask++) {",
      "        long long sum = 0;",
      "        for (int i = 0; i < mid; i++)",
      "            if (mask & (1 << i)) sum += a[i];",
      "        left.push_back(sum);",
      "    }",
      "",
      "    for (int mask = 0; mask < (1 << (n - mid)); mask++) {",
      "        long long sum = 0;",
      "        for (int i = 0; i < n - mid; i++)",
      "            if (mask & (1 << i)) sum += a[mid + i];",
      "        right.push_back(sum);",
      "    }",
      "",
      "    sort(right.begin(), right.end());",
      "    long long count = 0;",
      "",
      "    for (auto x : left) {",
      "        auto range = equal_range(right.begin(), right.end(), target - x);",
      "        count += (range.second - range.first);",
      "    }",
      "",
      "    return count;",
      "}"
    ],
    "description": "Meet in the Middle for subset sum"
  },

  "Offline Queries (Sort by R Example)": {
    "prefix": "misc_offline_queries",
    "body": [
      "// Offline queries sorted by R (example template)",
      "struct Query {",
      "    int l, r, idx;",
      "};",
      "",
      "vector<long long> solveOffline(vector<int> &arr, vector<Query> &queries) {",
      "    sort(queries.begin(), queries.end(), [](Query &a, Query &b) {",
      "        return a.r < b.r;",
      "    });",
      "",
      "    vector<long long> ans(queries.size());",
      "    long long current = 0;",
      "    int ptr = 0;",
      "",
      "    for (auto &q : queries) {",
      "        while (ptr <= q.r) {",
      "            current += arr[ptr];",
      "            ptr++;",
      "        }",
      "        ans[q.idx] = current; // modify per problem",
      "    }",
      "",
      "    return ans;",
      "}"
    ],
    "description": "Offline queries processing template"
  },

  "Sweep Line (Interval Overlap Count)": {
    "prefix": "misc_sweepline",
    "body": [
      "// Sweep line for max overlapping intervals",
      "int maxOverlap(vector<pair<int,int>> &intervals) {",
      "    vector<pair<int,int>> events;",
      "    for (auto &it : intervals) {",
      "        events.push_back({it.first, 1});",
      "        events.push_back({it.second, -1});",
      "    }",
      "",
      "    sort(events.begin(), events.end());",
      "",
      "    int current = 0, best = 0;",
      "    for (auto &e : events) {",
      "        current += e.second;",
      "        best = max(best, current);",
      "    }",
      "",
      "    return best;",
      "}"
    ],
    "description": "Sweep line for interval overlap"
  },

  "Coordinate Compression": {
    "prefix": "misc_coord_compress",
    "body": [
      "// Coordinate Compression",
      "vector<int> compress(vector<int> &a) {",
      "    vector<int> vals = a;",
      "    sort(vals.begin(), vals.end());",
      "    vals.erase(unique(vals.begin(), vals.end()), vals.end());",
      "",
      "    vector<int> res(a.size());",
      "    for (int i = 0; i < a.size(); i++) {",
      "        res[i] = lower_bound(vals.begin(), vals.end(), a[i]) - vals.begin();",
      "    }",
      "",
      "    return res;",
      "}"
    ],
    "description": "Coordinate compression utility"
  },

  "Randomized Hashing (Splitmix64)": {
    "prefix": "misc_random_hash",
    "body": [
      "// Randomized hashing using splitmix64",
      "struct custom_hash {",
      "    static uint64_t splitmix64(uint64_t x) {",
      "        x += 0x9e3779b97f4a7c15;",
      "        x = (x ^ (x >> 30)) * 0xbf58476d1ce4e5b9;",
      "        x = (x ^ (x >> 27)) * 0x94d049bb133111eb;",
      "        return x ^ (x >> 31);",
      "    }",
      "",
      "    size_t operator()(uint64_t x) const {",
      "        static const uint64_t FIXED_RANDOM =",
      "            chrono::steady_clock::now().time_since_epoch().count();",
      "        return splitmix64(x + FIXED_RANDOM);",
      "    }",
      "};",
      "",
      "// usage:",
      "// unordered_map<long long,int,custom_hash> mp;"
    ],
    "description": "Anti-hash hack randomized hashing"
  },

  "Mo on Tree (Euler + Mo Template)": {
    "prefix": "misc_mo_tree",
    "body": [
      "// Mo's Algorithm on Tree (Euler Tour Based Template)",
      "const int MAXN = 200005;",
      "vector<int> tree[MAXN];",
      "int st[MAXN], en[MAXN], euler[2*MAXN], timer = 0;",
      "",
      "void dfs(int u, int p) {",
      "    st[u] = timer;",
      "    euler[timer++] = u;",
      "    for (int v : tree[u]) {",
      "        if (v == p) continue;",
      "        dfs(v, u);",
      "    }",
      "    en[u] = timer;",
      "    euler[timer++] = u;",
      "}",
      "",
      "struct Query {",
      "    int l, r, idx;",
      "    int lca; // optional",
