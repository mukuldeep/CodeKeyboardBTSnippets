  "Variable Sliding Window (Longest Valid)": {
    "prefix": "two_pointers_variable_longest",
    "body": [
      "// Longest subarray satisfying condition",
      "int l = 0;",
      "long long sum = 0;",
      "int ans = 0;",
      "",
      "for (int r = 0; r < n; r++) {",
      "    sum += a[r];",
      "",
      "    while (sum > k) {",
      "        sum -= a[l];",
      "        l++;",
      "    }",
      "",
      "    ans = max(ans, r - l + 1);",
      "}"
    ],
    "description": ""
  },

