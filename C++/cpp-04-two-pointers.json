  "Two Pointers on Sorted Array (Pair Sum)": {
    "prefix": "two_pointers_pair_sum",
    "body": [
      "// Two pointers on sorted array to find pair with sum = target",
      "int l = 0, r = n - 1;",
      "",
      "while (l < r) {",
      "    long long sum = a[l] + a[r];",
      "    if (sum == target) {",
      "        // found",
      "        break;",
      "    } else if (sum < target) {",
      "        l++;",
      "    } else {",
      "        r--;",
      "    }",
      "}"
    ],
    "description": ""
  },

  "Three Sum Pattern (Sorted)": {
    "prefix": "two_pointers_three_sum",
    "body": [
      "// 3-Sum template (sorted array)",
      "sort(a.begin(), a.end());",
      "",
      "for (int i = 0; i < n; i++) {",
      "    int l = i + 1, r = n - 1;",
      "    while (l < r) {",
      "        long long sum = a[i] + a[l] + a[r];",
      "        if (sum == target) {",
      "            // process",
      "            l++; r--;",
      "        } else if (sum < target) {",
      "            l++;",
      "        } else {",
      "            r--;",
      "        }",
      "    }",
      "}"
    ],
