  "Minimum Length Subarray with Sum >= K": {
    "prefix": "two_pointers_min_len_sum",
    "body": [
      "// Minimum length subarray with sum >= k",
      "int l = 0;",
      "long long sum = 0;",
      "int ans = INT_MAX;",
      "",
      "for (int r = 0; r < n; r++) {",
      "    sum += a[r];",
      "",
      "    while (sum >= k) {",
      "        ans = min(ans, r - l + 1);",
      "        sum -= a[l];",
      "        l++;",
      "    }",
      "}",
      "",
      "if (ans == INT_MAX) ans = -1;"
    ],
    "description": ""
