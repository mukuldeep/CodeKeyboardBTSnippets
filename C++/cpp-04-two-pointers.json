{
  "Fixed Size Sliding Window (Sum)": {
    "prefix": "two_pointers_fixed_sum",
    "body": [
      "// Fixed window of size k (sum)",
      "long long maxSumK(vector<int>& a, int k) {",
      "    int n = a.size();",
      "    long long sum = 0;",
      "    for (int i = 0; i < k; i++) sum += a[i];",
      "    long long ans = sum;",
      "",
      "    for (int i = k; i < n; i++) {",
      "        sum += a[i] - a[i - k];",
      "        ans = max(ans, sum);",
      "    }",
      "    return ans;",
      "}"
    ],
    "description": ""
  },

