  "0/1 Knapsack": {
    "prefix": "dp_knapsack01",
    "body": [
      "// 0/1 Knapsack",
      "#include <bits/stdc++.h>",
      "using namespace std;",
      "",
      "int main() {",
      "    int n, W;",
      "    cin >> n >> W;",
      "    vector<int> wt(n), val(n);",
      "    for (int i = 0; i < n; i++) cin >> wt[i];",
      "    for (int i = 0; i < n; i++) cin >> val[i];",
      "",
      "    vector<long long> dp(W + 1, 0);",
      "",
      "    for (int i = 0; i < n; i++) {",
      "        for (int w = W; w >= wt[i]; w--) {",
      "            dp[w] = max(dp[w], dp[w - wt[i]] + val[i]);",
      "        }",
      "    }",
      "",
      "    cout << dp[W] << '\\n';",
      "}"
    ],
    "description": "0/1 Knapsack (1D optimized)"
  },

  "Subset Sum": {
    "prefix": "dp_subset_sum",
    "body": [
      "// Subset Sum",
      "#include <bits/stdc++.h>",
      "using namespace std;",
      "",
      "int main() {",
      "    int n, sum;",
      "    cin >> n >> sum;",
      "    vector<int> a(n);",
      "    for (int i = 0; i < n; i++) cin >> a[i];",
      "",
      "    vector<bool> dp(sum + 1, false);",
      "    dp[0] = true;",
      "",
      "    for (int i = 0; i < n; i++) {",
      "        for (int s = sum; s >= a[i]; s--) {",
      "            dp[s] = dp[s] || dp[s - a[i]];",
      "        }",
      "    }",
      "",
      "    cout << (dp[sum] ? \"YES\" : \"NO\") << '\\n';",
      "}"
    ],
    "description": "Subset Sum (boolean DP)"
  },

  "LIS O(n log n)": {
    "prefix": "dp_lis",
    "body": [
      "// Longest Increasing Subsequence O(n log n)",
      "#include <bits/stdc++.h>",
      "using namespace std;",
      "",
      "int main() {",
      "    int n;",
      "    cin >> n;",
      "    vector<int> a(n);",
      "    for (int i = 0; i < n; i++) cin >> a[i];",
      "",
      "    vector<int> lis;",
      "    for (int x : a) {",
      "        auto it = lower_bound(lis.begin(), lis.end(), x);",
      "        if (it == lis.end()) lis.push_back(x);",
      "        else *it = x;",
      "    }",
      "",
      "    cout << lis.size() << '\\n';",
      "}"
    ],
    "description": "Longest Increasing Subsequence O(n log n)"
  },

  "LCS": {
    "prefix": "dp_lcs",
    "body": [
      "// Longest Common Subsequence",
      "#include <bits/stdc++.h>",
      "using namespace std;",
      "",
      "int main() {",
      "    string a, b;",
      "    cin >> a >> b;",
      "    int n = a.size(), m = b.size();",
      "",
      "    vector<vector<int>> dp(n + 1, vector<int>(m + 1, 0));",
      "",
      "    for (int i = 1; i <= n; i++) {",
      "        for (int j = 1; j <= m; j++) {",
      "            if (a[i - 1] == b[j - 1])",
      "                dp[i][j] = dp[i - 1][j - 1] + 1;",
      "            else",
      "                dp[i][j] = max(dp[i - 1][j], dp[i][j - 1]);",
      "        }",
      "    }",
      "",
      "    cout << dp[n][m] << '\\n';",
      "}"
    ],
    "description": "Longest Common Subsequence"
  },

  "Digit DP": {
    "prefix": "dp_digit",
    "body": [
      "// Digit DP Template",
      "#include <bits/stdc++.h>",
      "using namespace std;",
      "",
      "string s;",
      "long long dp[20][2][200];",
      "",
      "long long solve(int pos, bool tight, int sum) {",
      "    if (pos == s.size()) return sum;",
      "    if (dp[pos][tight][sum] != -1) return dp[pos][tight][sum];",
      "",
      "    int limit = tight ? s[pos] - '0' : 9;",
      "    long long res = 0;",
      "",
      "    for (int d = 0; d <= limit; d++) {",
      "        res += solve(pos + 1, tight && (d == limit), sum + d);",
      "    }",
      "",
      "    return dp[pos][tight][sum] = res;",
      "}",
      "",
      "int main() {",
      "    long long n;",
      "    cin >> n;",
      "    s = to_string(n);",
      "    memset(dp, -1, sizeof(dp));",
      "    cout << solve(0, 1, 0) << '\\n';",
      "}"
    ],
    "description": "Digit DP template"
  },

  "Bitmask DP": {
    "prefix": "dp_bitmask",
    "body": [
      "// Bitmask DP (TSP style)",
      "#include <bits/stdc++.h>",
      "using namespace std;",
      "",
      "const int INF = 1e9;",
      "int n;",
      "int dist[20][20];",
      "int dp[1<<20][20];",
      "",
      "int solve(int mask, int u) {",
      "    if (mask == (1<<n) - 1) return 0;",
      "    if (dp[mask][u] != -1) return dp[mask][u];",
      "",
      "    int ans = INF;",
      "    for (int v = 0; v < n; v++) {",
      "        if (!(mask & (1<<v))) {",
      "            ans = min(ans, dist[u][v] + solve(mask | (1<<v), v));",
      "        }",
      "    }",
      "    return dp[mask][u] = ans;",
      "}"
    ],
    "description": "Bitmask DP (TSP pattern)"
  },

  "DP on Trees": {
    "prefix": "dp_tree",
    "body": [
      "// DP on Trees (subtree size example)",
      "#include <bits/stdc++.h>",
      "using namespace std;",
      "",
      "const int N = 2e5 + 5;",
      "vector<int> adj[N];",
      "int subtree[N];",
      "",
      "void dfs(int u, int parent) {",
      "    subtree[u] = 1;",
      "    for (int v : adj[u]) {",
      "        if (v == parent) continue;",
      "        dfs(v, u);",
      "        subtree[u] += subtree[v];",
      "    }",
      "}"
    ],
    "description": "DP on Trees template"
  },

  "Divide and Conquer DP": {
    "prefix": "dp_dnc",
    "body": [
      "// Divide and Conquer DP Optimization",
      "#include <bits/stdc++.h>",
      "using namespace std;",
      "",
      "const long long INF = 1e18;",
      "vector<long long> dp, prev_dp;",
      "",
      "long long cost(int l, int r) {",
      "    // define cost function",
      "    return 0;",
      "}",
      "",
      "void compute(int l, int r, int optL, int optR) {",
      "    if (l > r) return;",
      "    int mid = (l + r) / 2;",
      "    pair<long long, int> best = {INF, -1};",
      "",
      "    for (int k = optL; k <= min(mid, optR); k++) {",
      "        best = min(best, {prev_dp[k] + cost(k, mid), k});",
      "    }",
      "",
      "    dp[mid] = best.first;",
      "    int opt = best.second;",
      "",
      "    compute(l, mid - 1, optL, opt);",
      "    compute(mid + 1, r, opt, optR);",
      "}"
    ],
    "description": "Divide & Conquer DP Optimization"
  },

  "Knuth Optimization": {
    "prefix": "dp_knuth",
    "body": [
      "// Knuth Optimization Template",
      "#include <bits/stdc++.h>",
      "using namespace std;",
      "",
      "const long long INF = 1e18;",
      "long long dp[5005][5005];",
      "int opt[5005][5005];",
      "",
      "// Assumes quadrangle inequality holds",
      "for (int len = 2; len <= n; len++) {",
      "    for (int i = 0; i + len <= n; i++) {",
      "        int j = i + len;",
      "        dp[i][j] = INF;",
      "        for (int k = opt[i][j-1]; k <= opt[i+1][j]; k++) {",
      "            long long val = dp[i][k] + dp[k][j] + cost(i, j);",
      "            if (val < dp[i][j]) {",
      "                dp[i][j] = val;",
      "                opt[i][j] = k;",
      "            }",
      "        }",
      "    }",
      "}"
    ],
    "description": "Knuth Optimization"
  },

  "SOS DP": {
    "prefix": "dp_sos",
    "body": [
      "// Sum Over Subsets DP",
      "#include <bits/stdc++.h>",
      "using namespace std;",
      "",
      "int main() {",
      "    int n;",
      "    cin >> n;",
      "    int N = 1 << n;",
      "    vector<long long> f(N);",
      "",
      "    for (int mask = 0; mask < N; mask++) cin >> f[mask];",
      "",
      "    for (int i = 0; i < n; i++) {",
      "        for (int mask = 0; mask < N; mask++) {",
      "            if (mask & (1 << i)) {",
      "                f[mask] += f[mask ^ (1 << i)];",
      "            }",
      "        }",
      "    }",
      "",
      "    for (int mask = 0; mask < N; mask++)",
      "        cout << f[mask] << ' ';",
      "}"
    ],
    "description": "SOS DP (Sum over subsets)"
  }
