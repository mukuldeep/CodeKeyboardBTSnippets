{
  "Main Template": {
    "prefix": "maincpp",
    "body": [
      "#include <bits/stdc++.h>",
      "using namespace std;",
      "",
      "int main() {",
      "    ios::sync_with_stdio(false);",
      "    cin.tie(nullptr);",
      "",
      "    $0",
      "",
      "    return 0;",
      "}"
    ],
    "description": "Basic C++ template with fast IO"
  },

  "Fast IO Only": {
    "prefix": "fastio",
    "body": [
      "ios::sync_with_stdio(false);",
      "cin.tie(nullptr);",
      "cout.tie(nullptr);"
    ],
    "description": "Fast IO setup"
  },

  "Debug Macro": {
    "prefix": "debugmacro",
    "body": [
      "#ifdef LOCAL",
      "#define debug(x) cerr << #x << \" = \" << x << endl;",
      "#else",
      "#define debug(x)",
      "#endif"
    ],
    "description": "Debug macro with LOCAL flag"
  },

  "Common Macros": {
    "prefix": "macros",
    "body": [
      "#define all(x) (x).begin(), (x).end()",
      "#define rall(x) (x).rbegin(), (x).rend()",
      "#define pb push_back",
      "#define sz(x) (int)(x).size()"
    ],
    "description": "Frequently used macros"
  },

  "Type Aliases": {
    "prefix": "types",
    "body": [
      "using ll = long long;",
      "using ull = unsigned long long;",
      "using ld = long double;",
      "using pii = pair<int,int>;",
      "using pll = pair<long long,long long>;",
      "using vi = vector<int>;",
      "using vll = vector<long long>;"
    ],
    "description": "Common type aliases"
  },

  "Read Vector": {
    "prefix": "readvec",
    "body": [
      "vector<${1:int}> ${2:arr}(${3:n});",
      "for (auto &x : ${2:arr}) cin >> x;"
    ],
    "description": "Read vector input"
  },

  "Print Vector": {
    "prefix": "printvec",
    "body": [
      "for (auto &x : ${1:arr}) cout << x << \" \";",
      "cout << '\\n';"
    ],
    "description": "Print vector"
  },

  "GCD Function": {
    "prefix": "gcd",
    "body": [
      "long long gcd(long long a, long long b) {",
      "    return b == 0 ? a : gcd(b, a % b);",
      "}"
    ],
    "description": "Compute GCD"
  },

  "LCM Function": {
    "prefix": "lcm",
    "body": [
      "long long lcm(long long a, long long b) {",
      "    return a / gcd(a, b) * b;",
      "}"
    ],
    "description": "Compute LCM"
  },

  "Binary Exponentiation": {
    "prefix": "binexp",
    "body": [
      "long long binpow(long long a, long long b) {",
      "    long long res = 1;",
      "    while (b > 0) {",
      "        if (b & 1) res *= a;",
      "        a *= a;",
      "        b >>= 1;",
      "    }",
      "    return res;",
      "}"
    ],
    "description": "Binary exponentiation"
  },

  "Modular Exponentiation": {
    "prefix": "modexp",
    "body": [
      "long long modpow(long long a, long long b, long long mod) {",
      "    long long res = 1;",
      "    a %= mod;",
      "    while (b > 0) {",
      "        if (b & 1) res = (res * a) % mod;",
      "        a = (a * a) % mod;",
      "        b >>= 1;",
      "    }",
      "    return res;",
      "}"
    ],
    "description": "Modular exponentiation"
  },

  "Split String": {
    "prefix": "split",
    "body": [
      "vector<string> split(const string &s, char delim) {",
      "    vector<string> tokens;",
      "    stringstream ss(s);",
      "    string token;",
      "    while (getline(ss, token, delim)) {",
      "        tokens.push_back(token);",
      "    }",
      "    return tokens;",
      "}"
    ],
    "description": "Split string by delimiter"
  },

  "Sort Vector": {
    "prefix": "sortvec",
    "body": [
      "sort(${1:vec}.begin(), ${1:vec}.end());"
    ],
    "description": "Sort vector ascending"
  },

  "Reverse Vector": {
    "prefix": "revvec",
    "body": [
      "reverse(${1:vec}.begin(), ${1:vec}.end());"
    ],
    "description": "Reverse vector"
  },

  "Make Vector Unique": {
    "prefix": "uniqvec",
    "body": [
      "sort(${1:vec}.begin(), ${1:vec}.end());",
      "${1:vec}.erase(unique(${1:vec}.begin(), ${1:vec}.end()), ${1:vec}.end());"
    ],
    "description": "Sort and remove duplicates"
  },

  "Check Bit": {
    "prefix": "checkbit",
    "body": [
      "bool checkBit(int mask, int i) {",
      "    return mask & (1 << i);",
      "}"
    ],
    "description": "Check if ith bit is set"
  },

  "Set Bit": {
    "prefix": "setbit",
    "body": [
      "mask |= (1 << ${1:i});"
    ],
    "description": "Set ith bit"
  },

  "Clear Bit": {
    "prefix": "clearbit",
    "body": [
      "mask &= ~(1 << ${1:i});"
    ],
    "description": "Clear ith bit"
  },

  "Count Bits": {
    "prefix": "countbits",
    "body": [
      "int cnt = __builtin_popcount(${1:x});"
    ],
    "description": "Count set bits"
  },

  "Random Generator": {
    "prefix": "rng",
    "body": [
      "mt19937 rng(chrono::steady_clock::now().time_since_epoch().count());"
    ],
    "description": "Mersenne Twister RNG"
  },

  "For Loop": {
    "prefix": "fori",
    "body": [
      "for (int i = 0; i < ${1:n}; ++i) {",
      "    $0",
      "}"
    ],
    "description": "Standard for loop"
  },

  "Range Loop": {
    "prefix": "forauto",
    "body": [
      "for (auto &${1:x} : ${2:container}) {",
      "    $0",
      "}"
    ],
    "description": "Range-based loop"
  }
}