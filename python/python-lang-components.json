  "Fast IO Setup": {
    "prefix": "fastio",
    "body": [
      "import sys",
      "input = sys.stdin.readline"
    ],
    "description": "Fast input setup"
  },

  "Read Int": {
    "prefix": "readint",
    "body": [
      "n = int(input().strip())"
    ],
    "description": "Read single integer"
  },

  "Read Int List": {
    "prefix": "readlist",
    "body": [
      "arr = list(map(int, input().split()))"
    ],
    "description": "Read list of integers"
  },

  "Read Matrix": {
    "prefix": "readmatrix",
    "body": [
      "n, m = map(int, input().split())",
      "mat = [list(map(int, input().split())) for _ in range(n)]"
    ],
    "description": "Read 2D matrix"
  },

  "GCD": {
    "prefix": "gcd",
    "body": [
      "from math import gcd"
    ],
    "description": "Import gcd"
  },

  "LCM Function": {
    "prefix": "lcm",
    "body": [
      "def lcm(a, b):",
      "    return a // gcd(a, b) * b"
    ],
    "description": "Compute LCM"
  },

  "Binary Exponentiation": {
    "prefix": "binexp",
    "body": [
      "def binpow(a, b):",
      "    res = 1",
      "    while b:",
      "        if b & 1:",
      "            res *= a",
      "        a *= a",
      "        b >>= 1",
      "    return res"
    ],
    "description": "Binary exponentiation"
  },

  "Modular Exponentiation": {
    "prefix": "modexp",
    "body": [
      "def modpow(a, b, mod):",
      "    res = 1",
      "    a %= mod",
      "    while b:",
      "        if b & 1:",
      "            res = (res * a) % mod",
      "        a = (a * a) % mod",
      "        b >>= 1",
      "    return res"
    ],
    "description": "Modular exponentiation"
  },

  "DefaultDict": {
    "prefix": "defaultdict",
